# URL base del backend Node/Express per a Overture Maps Places.
#
# En local (si tens el backend corrent):
# VITE_API_BASE_URL=http://localhost:3000
#
# En producció (backend desplegat a Render):
VITE_API_BASE_URL=https://editor-mapes.onrender.com
#
# Pots usar directament el backend de Render també en local sense
# instal·lar res — la cache del servidor evita trucades redundants.
